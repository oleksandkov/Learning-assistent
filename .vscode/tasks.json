{
  "version": "2.0.0",
  "tasks": [
    {
      // Run the file in the terminal via VS code
      "label": "Compile and Run any .cpp file",
      "type": "shell",
      "command": "cd \"${fileDirname}\"; chcp 65001 >$null; g++ ${fileBasename} -o ${fileBasenameNoExtension}.exe; .\\${fileBasenameNoExtension}.exe",
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      // Run the file in the terminal via Command panel (cmd window) - recomended ctrl + alt + m
      "label": "Compile and Run any .cpp file in Command panel",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/c",
        "start cmd.exe /k chcp 65001 ^& cd /d ${fileDirname} ^&^& g++ ${fileBasename} -o ${fileBasenameNoExtension}.exe ^&^& ${fileBasenameNoExtension}.exe ^& pause"
      ],
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      // Compile and run .cpp file in a new window that closes automatically after execution
      "label": "Compile and Run any .cpp file (auto-close window)",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/c",
        "start cmd.exe /c chcp 65001 ^& cd /d ${fileDirname} ^&^& g++ ${fileBasename} -o ${fileBasenameNoExtension}.exe ^&^& ${fileBasenameNoExtension}.exe"
      ],
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      // Do not work
      "type": "shell",
      "label": "C/C++: g++.exe build active file",
      "command": "chcp 65001 >$null; C:\\msys64\\ucrt64\\bin\\g++.exe -fdiagnostics-color=always -g ${file} -o ${fileDirname}\\${fileBasenameNoExtension}.exe",
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task generated by Debugger."
    },
    {
      // Useless
      "label": "Analyze and Explain Code (Shell)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/analyze_and_explain.ps1",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "Start All MCP Servers",
      "type": "shell",
      "command": "npx -y @upstash/context7-mcp@latest & npx -y @modelcontextprotocol/server-sequential-thinking & npx -y @modelcontextprotocol/server-memory & npx -y @modelcontextprotocol/server-filesystem C:/Users/muaro/Documents/GitHub/Learning-assistent & npx -y qodo-mcp-server",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Toggle Tab Completion",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/toggle_tab_completion.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Start All MCP Servers (parallel)",
      "dependsOn": [
        "Start MCP: context7",
        "Start MCP: sequentialthinking",
        "Start MCP: memory",
        "Start MCP: filesystem",
        "Start MCP: qodo"
      ],
      "dependsOrder": "parallel"
    },
    {
      "label": "Start MCP: context7",
      "type": "shell",
      "command": "npx -y @upstash/context7-mcp@latest",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Start MCP: sequentialthinking",
      "type": "shell",
      "command": "npx -y @modelcontextprotocol/server-sequential-thinking",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Start MCP: memory",
      "type": "shell",
      "command": "npx -y @modelcontextprotocol/server-memory",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Start MCP: filesystem",
      "type": "shell",
      "command": "npx -y @modelcontextprotocol/server-filesystem C:/Users/muaro/Documents/GitHub/Learning-assistent",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Start MCP: qodo",
      "type": "shell",
      "command": "npx -y qodo-mcp-server",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Run Current .bat File (UTF-8)",
      "type": "process",
      "command": "cmd.exe",
      "args": ["/c", "start cmd.exe /k chcp 65001 ^&^& call ${file} ^& pause"],
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      // Compile and run SFML project - works from any file in any SFML project with src/include/bin structure
      "label": "Compile and Run SFML .cpp file",
      "type": "shell",
      "command": "$projectRoot = Split-Path -Parent (Split-Path -Parent '${fileDirname}'); if (Test-Path \"$projectRoot/src\") { $projectRoot } else { $projectRoot = Split-Path -Parent '${fileDirname}'; if (Test-Path \"$projectRoot/src\") { $projectRoot } else { $projectRoot = '${fileDirname}' } }; Set-Location -LiteralPath $projectRoot; chcp 65001 >$null; $sourceFiles = Get-ChildItem -Path src -Filter *.cpp | ForEach-Object { $_.FullName }; g++ $sourceFiles -Iinclude -IC:/msys64/ucrt64/include -LC:/msys64/ucrt64/lib -o bin/main.exe -lsfml-graphics -lsfml-window -lsfml-system; if ($?) { & ./bin/main.exe }",
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
