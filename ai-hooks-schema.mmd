flowchart TD
    A[AI Agent decides next action] --> B[Lifecycle event emitted\nbeforeToolUse or afterToolUse]
    B --> C[Hooks Loader scans hooks directory\nJSON hook definitions]
    C --> D{Any hooks bound\nto this event?}
    D -- No --> Z[Continue normal agent flow]
    D -- Yes --> E[Evaluate hooks in deterministic order\npriority then name order]

    E --> F[Hook: Command policy guard]
    F --> G{Dangerous command?}
    G -- Yes --> H[Block execution\nreturn denial reason]
    G -- No --> I[Allow command path]

    I --> J[Hook: Quality gate\nrun linter and test policy]
    J --> K{Checks pass?}
    K -- No --> L[Fail fast / request fix]
    K -- Yes --> M[Proceed]

    M --> N[Tool executes or post event runs]
    N --> O[Hook: Audit trail writer]
    O --> P[Write structured log\nevent tool args decision timestamp]
    P --> Q[Return control to AI agent]

    H --> Q
    L --> Q
    Z --> Q

    Q --> R[Next lifecycle event]

    classDef guard fill:#ffe4e6,stroke:#be123c,color:#111827;
    classDef quality fill:#fff7ed,stroke:#c2410c,color:#111827;
    classDef audit fill:#ecfeff,stroke:#0e7490,color:#111827;
    classDef core fill:#eef2ff,stroke:#4338ca,color:#111827;

    class F,G,H guard;
    class J,K,L quality;
    class O,P audit;
    class A,B,C,D,E,N,Q,R,Z core;